# FastAPI app settings
MODEL_NAME=stig-ai
TOP_K=20
AI_CONTEXT_K=5
CACHE_TTL=300
RELEVANCE_THRESHOLD=0.35

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=security

# Memcached
MEMCACHED_HOST=127.0.0.1
MEMCACHED_PORT=11211

# Ollama
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=mistral

# STIG ingestion
STIG_DIR=stig
BATCH_SIZE=500
